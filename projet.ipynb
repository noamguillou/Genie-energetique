    "h_1= CP.PropsSI(\"H\",\"P\",P_1,\"T\",T_1,\"CO2\")\n",
    "s_1 = CP.PropsSI(\"S\",\"P\",P_1,\"H\",h_1,\"CO2\")\n",
    "h_4 = CP.PropsSI(\"H\",\"P\",P_4,\"T\",T_4,\"CO2\")\n",
    "s_4 = CP.PropsSI(\"S\",\"P\",P_4,\"H\",h_4,\"CO2\")\n",
    "print(f\"h_1: {h_1*1e-3} kJ/kg\", f\"s_1: {s_1*1e-3} kJ/kg/K\", f\"h_3: {h_4*1e-3} kJ/kg\", f\"s_3: {s_4*1e-3} kJ/kg/K\", sep=\"\\n\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 404,
   "id": "cd6882d6",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
