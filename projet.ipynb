   ],
   "source": [
    "q_m = 100 # kg/s\n",
    "\n",
    "# Echange d'énergie :\n",
    "print(\"Echange d'énergie :\",\n",
    "      f\"Chaudière : {q_m*(h_4_reel-h_1)*1e-6} MW\",\n",
    "      f\"Turbine : {q_m*(h_1-h_2_reel)*1e-6} MW\",\n",
    "      f\"Source froide :{q_m*(h_2_reel-h_3)*1e-6} MW\",\n",
    "      f\"Compresseur : {q_m*(h_3-h_4_reel)*1e-6} MW\", sep=\"\\n\")\n",
    "\n",
    "# Puissance thermique :\n",
    "q_chaude = (h_1-h_4_reel)*q_m*1e-6\n",
    "q_froide = (h_3-h_2_reel)*q_m*1e-6\n",
    "print(\"Puissance tyhermique :\",\n",
    "      f\"Chaudière : {q_chaude} MW\",\n",
    "      f\"Turbine : 0 MW car adiabatique\",\n",
    "      f\"Source froide : {q_froide} MW\",\n",
    "      f\"Compresseur : 0 MW car adiabatique\", sep=\"\\n\")\n",
    "\n",
    "# Travail utile :\n",
    "w_turbine = (h_2_reel-h_1)*q_m*1e-6\n",
    "w_compresseur = (h_4_reel-h_3)*q_m*1e-6\n",
    "print(\"Travail utile :\",\n",
    "      f\"Chaudière : 0 MW car pas de travail\",\n",
    "      f\"Turbine : {w_turbine} MW\",\n",
    "      f\"Source froide : 0 MW car pas de travail \",\n",
    "      f\"Compresseur : {w_compresseur} MW\", sep=\"\\n\")\n",
    "\n",
    "# Echange d'éxergie :\n",
    "T0 = 280 #K, fixé arbitrairement selon la page 32 du cours. \n",
    "print(\"Echange d'éxergie :\",\n",
    "      f\"Chaudière : {q_m*((h_4_reel-h_1)-T0*(s_4-s_1))*1e-6} MW\",\n",
    "      f\"Turbine : {q_m*((h_1-h_2_reel)-T0*(s_1-s_2))*1e-6} MW\",\n",
    "      f\"Source froide :{q_m*((h_2_reel-h_3)-T0*(s_2-s_3))*1e-6} MW\",\n",
    "      f\"Compresseur : {q_m*((h_3-h_4_reel)-T0*(s_3-s_4))*1e-6} MW\", sep=\"\\n\")\n",
    "\n",
    "# Exergie des échanges :\n",
    "T_froide = 293.15 # K, source froide \n",
    "T_chaude = 873.15 # K, source chaude\n",
    "eta_Carnot = 1 - T_froide / T_chaude\n",
    "print(\"Exergie des échanges :\",\n",
    "      f\"Chaudière : {q_chaude*eta_Carnot} MW\",\n",
    "      f\"Source froide : {q_froide*eta_Carnot} MW\",sep=\"\\n\")\n",
    "\n",
    "# Destruction d'exergie :\n",
    "print(\"Destruction d'exergie :\",\n",
    "      f\"Chaudière : {q_m*((h_4_reel-h_1)-T0*(s_4-s_1))*1e-6} MW\",\n",
    "      f\"Turbine : {q_m*((h_1-h_2_reel)-T0*(s_1-s_2))*1e-6-w_turbine}MW\",\n",
    "      f\"Source froide :{q_m*((h_2_reel-h_3)-T0*(s_2-s_3))*1e-6} MW\",\n",
    "      f\"Compresseur : {q_m*((h_3-h_4_reel)-T0*(s_3-s_4))*1e-6-w_compresseur} MW\", sep=\"\\n\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e35a59ea",
   "metadata": {},
   "source": [
    "*$\\textbf{Q-1.2 :}$ Calculer les rendements énergétique et exergétique.*"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "05432995",
   "metadata": {},
   "source": [
    "• Rendement énergétique\n",
    "\n",
    "Pour calculer le rendement énergétique, on a besoin de connaître la puissance délivrée et la chaleur délivrée par le système."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 344,
   "id": "52c0d062",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "w_turbine = -22.7 MW\n",
      "w_compresseur = 16.4 MW\n",
      "w_net = -6.3 MW\n",
      "q_chaude = 41.0 MW\n"
     ]
    }
   ],
   "source": [
    "w_net = w_compresseur + w_turbine        # MW\n",
    "print(f\"w_turbine = {w_turbine:.1f} MW\")\n",
    "print(f\"w_compresseur = {w_compresseur:.1f} MW\")\n",
    "print(f\"w_net = {w_net:.1f} MW\")\n",
    "print(f\"q_chaude = {q_chaude:.1f} MW\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 345,
   "id": "2be49318",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Le rendement énergétique est de 0.1538 (15.38%).\n"
     ]
    }
   ],
   "source": [
    "eta_ener = abs(w_net) / q_chaude\n",
    "print(f\"Le rendement énergétique est de {eta_ener:.4f} ({eta_ener:.2%}).\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f2d8047a",
   "metadata": {},
   "source": [
    "• Rendement exergétique"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 346,
   "id": "675300ce",
   "metadata": {},
   "outputs": [
