     ]
    }
   ],
   "source": [
    "eta_Carnot = 1 - T_froide / T_chaude\n",
    "print(f\"Le rendement de Carnot est de {eta_Carnot:.4f} ({eta_Carnot:.2%}).\")\n",
    "\n",
    "eta_exer = eta_ener / eta_Carnot\n",
    "print(f\"Le rendement exergétique est de {eta_exer:.4f} ({eta_exer:.2%}).\")"
   ]
  },
  {
   "cell_type": "markdown",
