   "id": "053e3bb6",
   "metadata": {},
   "outputs": [],
   "source": [
    "import CoolProp.CoolProp as CP\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "81e1ec6a",
   "metadata": {},
   "source": [
    "# Cycles moteurs au $CO_{2}$ supercritique #\n",
    "\n",
    "## 1. Cycle de Brayton simple au $CO_{2}$ (gazeux) ##"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e354a2d9",
   "metadata": {},
   "source": [
    "*$\\textbf{Q-1.1 :}$ Dessiner le cycle sur un diagramme (T-s) et faire le calcul complet des états (tableau 1) et des transformations (tableau 2).*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 336,
   "id": "5de2ef65",
   "metadata": {},
   "outputs": [],
   "source": [
    "#Définition des constantes connues :\n",
    "P_1 = 70.e5 #Pa\n",
    "T_1 = 848 #K\n",
    "P_3 = 10.e5 #Pa\n",
    "T_3 = 303 #K"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 337,
   "id": "f3243b77",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "h_1: 1075.5167755789087 kJ/kg\n",
      "s_1: 2.991627708649479 kJ/kg/K\n",
      "h_3: 501.6007192973885 kJ/kg\n",
      "s_3: 2.298529627716221 kJ/kg/K\n"
     ]
    }
   ],
   "source": [
    "#Calcul des enthalpies et entropies\n",
    "h_1= CP.PropsSI(\"H\",\"P\",P_1,\"T\",T_1,\"CO2\")\n",
    "s_1 = CP.PropsSI(\"S\",\"P\",P_1,\"H\",h_1,\"CO2\")\n",
    "h_3 = CP.PropsSI(\"H\",\"P\",P_3,\"T\",T_3,\"CO2\")\n",
    "s_3 = CP.PropsSI(\"S\",\"P\",P_3,\"H\",h_3,\"CO2\")\n",
    "print(f\"h_1: {h_1*1e-3} kJ/kg\", f\"s_1: {s_1*1e-3} kJ/kg/K\", f\"h_3: {h_3*1e-3} kJ/kg\", f\"s_3: {s_3*1e-3} kJ/kg/K\", sep=\"\\n\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e104a9aa",
   "metadata": {},
   "source": [
    "• Transformation 1->2 :\n",
    "\n",
    " On suppose d'abord la transformation adiabatique réversible, c'est à dire isentropique. "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 338,
   "id": "f6165d84",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "T_2_is = 610.03 K  (336.88 °C)\n",
      "h_2_is: 808.8685606403932 kJ/kg\n"
     ]
    }
   ],
   "source": [
    "P_2 = P_3   \n",
    "# Transformation supposée isentropique : s_2 = s_1  \n",
    "T_2_is = CP.PropsSI(\"T\", \"P\", P_2, \"S\", s_1, \"CO2\")\n",
    "print(f\"T_2_is = {T_2_is:.2f} K  ({T_2_is - 273.15:.2f} °C)\")\n",
    "\n",
    "h_2_is= CP.PropsSI(\"H\",\"P\",P_2,\"T\",T_2_is,\"CO2\")\n",
    "print(f\"h_2_is: {h_2_is*1e-3} kJ/kg\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6105e339",
   "metadata": {},
   "source": [
    "On étudie maintenant la transformation réelle 1->2 : "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 339,
   "id": "a23ee860",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "h_2_reel: 848.8657928811706 kJ/kg\n",
      "T_2 = 646.47 K  (373.32 °C)\n",
      "s_2: 3.055304815340956 kJ/kg/K\n"
     ]
    }
   ],
   "source": [
    "eta_t = 0.85 # rendement isentropique turbine \n",
    "h_2_reel = h_1 - eta_t * (h_1 - h_2_is)\n",
    "print(f\"h_2_reel: {h_2_reel*1e-3} kJ/kg\")\n",
    "\n",
    "T_2 = CP.PropsSI(\"T\", \"P\", P_2, \"H\", h_2_reel, \"CO2\")\n",
    "print(f\"T_2 = {T_2:.2f} K  ({T_2 - 273.15:.2f} °C)\")\n",
    "\n",
    "s_2 = CP.PropsSI(\"S\",\"P\",P_2,\"H\",h_2_reel,\"CO2\")\n",
    "print(f\"s_2: {s_2*1e-3} kJ/kg/K\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ff5a1001",
   "metadata": {},
   "source": [
    "• Transformation 3->4:\n",
    "\n",
    "De manière analogue, on suppose d'abord la transformation 3->4 isentropique."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 340,
   "id": "b913eb41",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "T_4_is = 463.43 K  (190.28 °C)\n",
      "h_4_is: 632.4325566799653 kJ/kg\n"
     ]
    }
   ],
   "source": [
    "P_4 = P_1\n",
    "T_4_is = CP.PropsSI(\"T\", \"P\", P_4, \"S\", s_3, \"CO2\")\n",
    "print(f\"T_4_is = {T_4_is:.2f} K  ({T_4_is - 273.15:.2f} °C)\")\n",
    "\n",
    "h_4_is= CP.PropsSI(\"H\",\"P\",P_4,\"T\",T_4_is,\"CO2\")\n",
    "print(f\"h_4_is: {h_4_is*1e-3} kJ/kg\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f33ab3b4",
   "metadata": {},
   "source": [
    "Pour la transformation réelle 3->4 : "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 341,
   "id": "8900921a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "h_4_reel: 665.1405160256095 kJ/kg\n",
      "T_4 = 492.72 K  (219.57 °C)\n",
      "s_4: 2.3669687237051704 kJ/kg/K\n"
     ]
    }
   ],
   "source": [
    "eta_c = 0.8 # rendement isentropique compresseur \n",
    "h_4_reel = h_3 + (h_4_is - h_3)/eta_c\n",
    "print(f\"h_4_reel: {h_4_reel*1e-3} kJ/kg\")\n",
    "\n",
    "T_4 = CP.PropsSI(\"T\", \"P\", P_4, \"H\", h_4_reel, \"CO2\")\n",
    "print(f\"T_4 = {T_4:.2f} K  ({T_4 - 273.15:.2f} °C)\")\n",
    "\n",
    "s_4 = CP.PropsSI(\"S\",\"P\",P_4,\"H\",h_4_reel,\"CO2\")\n",
    "print(f\"s_4: {s_4*1e-3} kJ/kg/K\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 342,
   "id": "94e3821f",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "/var/folders/bv/ykzk9d_14271yt6j934j38jw0000gn/T/ipykernel_85604/3794019479.py:30: UserWarning: color is redundantly defined by the 'color' keyword argument and the fmt string \"k--\" (-> color='k'). The keyword argument will take precedence.\n",
      "  plt.plot([points_s[0], points_s[0]], [points_T[0], T_2_is],'k--', color='black', label='transforation isentropique')\n",
      "/var/folders/bv/ykzk9d_14271yt6j934j38jw0000gn/T/ipykernel_85604/3794019479.py:31: UserWarning: color is redundantly defined by the 'color' keyword argument and the fmt string \"k--\" (-> color='k'). The keyword argument will take precedence.\n",
      "  plt.plot([points_s[2], points_s[2]], [points_T[2], T_4_is], 'k--', color='black')\n"
     ]
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "points_s = [s_1*1e-3, s_2*1e-3, s_3*1e-3, s_4*1e-3]\n",
    "points_T = [T_1, T_2, T_3, T_4]\n",
    "points_P= [P_1, P_2, P_3, P_4]\n",
    "\n",
    "# Programme pour tracer les isobares\n",
    "def transfo_isobare(T_in, T_out, P, n=100):\n",
    "    Ss, Ts = [], []\n",
    "    for t in np.linspace(T_in, T_out, n):\n",
    "        try:\n",
    "            s_val = CP.PropsSI(\"S\", \"P\", P, \"T\", t, \"CO2\") * 1e-3  # Conversion en kJ/kg/K\n",
    "            Ss.append(s_val)\n",
    "            Ts.append(t)\n",
    "        except:\n",
    "            pass\n",
    "    return [np.array(Ss), np.array(Ts)]\n",
    "\n",
    "# Affichage des 4 points états\n",
    "plt.scatter(points_s, points_T, marker='o', color='red')\n",
    "for i, txt in enumerate(['1', '2', '3', '4']):\n",
    "    plt.annotate(txt, (points_s[i], points_T[i]), textcoords=\"offset points\", xytext=(5,5), ha='center')\n",
    "# Tracé des isobares\n",
    "S_23, T_23 = transfo_isobare( T_2, T_3, P_2)\n",
    "plt.plot(S_23, T_23, color='blue')\n",
    "S_41, T_41 = transfo_isobare(T_4, T_1, P_4)\n",
    "plt.plot(S_41, T_41, color='blue')\n",
    "# Tracé des transformations réelles\n",
    "plt.plot([points_s[0], points_s[1]], [points_T[0], points_T[1]], color='blue')\n",
    "plt.plot([points_s[2], points_s[3]], [points_T[2], points_T[3]], color='blue')\n",
    "# Tracé des transformations isentropiques\n",
    "plt.plot([points_s[0], points_s[0]], [points_T[0], T_2_is],'k--', color='black', label='transforation isentropique')\n",
    "plt.plot([points_s[2], points_s[2]], [points_T[2], T_4_is], 'k--', color='black')\n",
    "\n",
    "# Affichage du diagramme\n",
    "plt.xlabel('Entropie (kJ/kg/K)')\n",
    "plt.ylabel('Température (K)')\n",
    "plt.title('Cycle de Brayton sur un diagramme T-s')\n",
    "plt.legend()\n",
    "plt.grid()\n",
    "plt.show()"
   ]
  },
  {
